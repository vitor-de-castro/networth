<div class="ai-message-pair">
  <div class="ai-question-bubble">
    <div class="bubble-header">You</div>
    <div class="bubble-content"><%= sanitize(question, tags: []) %></div>
  </div>

  <div class="ai-answer-bubble">
    <div class="bubble-header">AI Advisor</div>
    <div class="bubble-content">
      <% answer.to_s.split("\n\n").each do |paragraph| %>
        <p><%= simple_format(sanitize(paragraph, tags: %w[strong em ul li])) %></p>
      <% end %>
    </div>
  </div>
</div>
