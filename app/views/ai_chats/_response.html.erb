<div class="ai-message">
  <div class="ai-question">
    <span class="ai-label">You</span>
    <p><%= sanitize(question, tags: []) %></p>
  </div>
  <div class="ai-answer">
    <span class="ai-label">AI Advisor</span>
    <% answer.to_s.split("\n").each do |paragraph| %>
      <% unless paragraph.strip.empty? %>
        <p><%= simple_format(sanitize(paragraph, tags: %w[strong em ul li])) %></p>
      <% end %>
    <% end %>
  </div>
</div>
