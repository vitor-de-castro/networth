<%= render 'shared/flash' %>

<div class="networth-container">
  <div class="networth-content">

    <%# Net Worth Card %>
    <div class="networth-card">
      <h2>Total Net Worth</h2>
      <p class="amount">
        <%= @currency_symbol %><%= number_with_delimiter(@total_net_worth.round(2), delimiter: ',') %>
      </p>
    </div>

    <%# Add Asset Button %>
    <div class="add-asset-buttons">
  <%= link_to "+ Add Asset", new_asset_path, class: "add-asset-btn" %>
  <%= link_to "📊 Bulk Add Stocks", bulk_new_assets_path, class: "add-asset-btn" %>
  </div>

    <%# Quick Stats Cards %>
    <% if @assets.any? %>
      <div class="stats-grid">

        <%# Biggest Asset %>
        <div class="stat-card">
          <div class="stat-icon">💎</div>
          <div class="stat-content">
            <div class="stat-label">Biggest Asset</div>
            <div class="stat-value"><%= @biggest_asset.name %></div>
            <div class="stat-subtext">
              <%= @currency_symbol %><%= number_with_delimiter((@biggest_asset.value * @rate).round(0), delimiter: ',') %>
            </div>
          </div>
        </div>

        <%# Portfolio Diversity %>
        <div class="stat-card">
          <div class="stat-icon">📊</div>
          <div class="stat-content">
            <div class="stat-label">Portfolio Diversity</div>
            <div class="stat-value"><%= @categories_count %> Categories</div>
            <div class="stat-subtext">
              <%= case @categories_count
                  when 1..2 then "Low diversity"
                  when 3..4 then "Moderate diversity"
                  when 5..6 then "Well diversified"
                  else "Highly diversified"
                  end %>
            </div>
          </div>
        </div>

        <%# Top Category %>
        <% if @top_category %>
          <div class="stat-card">
            <div class="stat-icon">🎯</div>
            <div class="stat-content">
              <div class="stat-label">Top Category</div>
              <div class="stat-value"><%= @top_category[0] %></div>
              <div class="stat-subtext">
                <%= @currency_symbol %><%= number_with_delimiter(@top_category[1].round(0), delimiter: ',') %>
                (<%= (@top_category[1] / @total_net_worth * 100).round(1) %>%)
              </div>
            </div>
          </div>
        <% end %>

        <%# Crypto Allocation %>
        <% if @crypto_percentage > 0 %>
          <div class="stat-card">
            <div class="stat-icon">₿</div>
            <div class="stat-content">
              <div class="stat-label">Crypto Allocation</div>
              <div class="stat-value"><%= @crypto_percentage %>%</div>
              <div class="stat-subtext">
                <%= @currency_symbol %><%= number_with_delimiter((current_user.assets.where(category: 'Crypto').sum(:value) * @rate).round(0), delimiter: ',') %>
              </div>
            </div>
          </div>
        <% end %>

      </div>
    <% end %>

    <%# Charts Section %>
    <% if @assets.any? %>
      <div class="charts-section" id="charts">

        <%# Pie Chart %>
        <div class="chart-card">
          <h3 class="chart-title">Asset Breakdown</h3>
          <%= pie_chart @assets_by_category,
                        colors: ["#efd95bff", "#4FC3F7", "#81C784", "#FF8A65", "#CE93D8", "#F06292", "#80DEEA"],
                        legend: true,
                        height: "300px" %>
        </div>

        <%# Category Breakdown List %>
        <div class="chart-card">
          <h3 class="chart-title">By Category</h3>
          <div class="category-list">
            <% @assets_by_category.sort_by { |_, v| -v }.each do |category, value| %>
              <div class="category-item">
                <span class="category-name">
                  <span class="category-icon-small"><%= category_icon(category) %></span>
                  <%= category %>
                </span>
                <div class="category-bar-wrapper">
                  <div class="category-bar"
                       style="width: <%= (@total_net_worth > 0 ? (value / @total_net_worth * 100) : 0).round(1) %>%">
                  </div>
                </div>
                <span class="category-value">
                  <%= @currency_symbol %><%= number_with_delimiter(value.round(2), delimiter: ',') %>
                  <span class="category-percent">
                    (<%= (@total_net_worth > 0 ? (value / @total_net_worth * 100) : 0).round(1) %>%)
                  </span>
                </span>
              </div>
            <% end %>
          </div>
        </div>

      </div>
    <% end %>

    <%# Net Worth History %>
    <% if @history_data.any? %>
      <div class="history-section">
        <h2 class="history-title">Net Worth Growth (Last 30 Days)</h2>
        <div class="history-table-card">
          <table class="history-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Net Worth</th>
                <th>Change</th>
              </tr>
            </thead>
            <tbody>
              <% sorted_data = @history_data.sort_by { |date, _| date }.reverse %>
  <% previous_value = nil %>
  <% sorted_data.each_with_index do |(date, value), index| %>
  <tr>
    <td><%= date.strftime('%b %d, %Y') %></td>
    <td class="value">
      <%= @currency_symbol %><%= number_with_delimiter(value.round(0), delimiter: ',') %>
    </td>
    <td>
      <% if index < sorted_data.length - 1 %>
        <% prev_date, prev_value = sorted_data[index + 1] %>
        <% change = value - prev_value %>
        <% change_percent = ((change / prev_value) * 100).round(1) %>
        <span class="change <%= change >= 0 ? 'positive' : 'negative' %>">
          <%= change >= 0 ? '▲' : '▼' %>
          <%= @currency_symbol %><%= number_with_delimiter(change.abs.round(0), delimiter: ',') %>
          (<%= change >= 0 ? '+' : '' %><%= change_percent %>%)
        </span>
      <% else %>
        <span class="change neutral">—</span>
      <% end %>
    </td>
    </tr>
  <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>

    <%# Assets List %>
<div class="assets-section">
  <h2>Your Assets (<%= @assets.count %>)</h2>

  <% if @assets.any? %>
    <div class="assets-list">
      <% @assets.each do |asset| %>
        <div class="asset-item">
          <div class="asset-icon">
            <%= category_icon(asset.category) %>
          </div>
          <div class="asset-info">
            <h3>
              <%= asset.name %>
              <% if asset.track_live? && asset.symbol.present? %>
                <span class="live-badge">LIVE</span>
              <% end %>
            </h3>
            <p class="asset-meta">
              <span class="category"><%= asset.category %></span>
              <% if asset.track_live? && asset.quantity.present? %>
                <span class="separator">•</span>
                <span class="quantity"><%= asset.quantity %> <%= asset.symbol %></span>
              <% end %>
            </p>
          </div>
          <div class="asset-actions">
            <p class="value">
              <%= @currency_symbol %><%= number_with_delimiter((asset.live_value * @rate).round(2), delimiter: ',') %>
            </p>
            <div class="actions">
              <%= link_to "Edit", edit_asset_path(asset), class: "edit-link" %>
              <%= button_to "Delete", asset_path(asset), method: :delete, class: "delete-btn",
                            data: { turbo_confirm: "Are you sure?", disable_with: '🗑️ Deleting...' } %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
    <div class="empty-icon">📈</div>
    <h3 class="empty-title">No Assets Yet</h3>
    <p class="empty-subtitle">Start tracking your net worth by adding your first asset</p>
    <div class="empty-actions">
      <%= link_to "+ Add Your First Asset", new_asset_path, class: "add-asset-btn" %>
      <p class="empty-hint">
        💡 <strong>Tip:</strong> You can track stocks and crypto with live prices,
        or manually add property, vehicles, and other assets.
      </p>
    </div>
  </div>
  <% end %>
</div>

<%# Market Prices Widget %>
<div class="market-widget" id="live-markets">
  <h3 class="market-title">Live Markets</h3>

  <div class="market-grid" id="market-grid">
    <%# Initial skeleton cards %>
    <% 7.times do %>
      <div class="market-card-skeleton">
        <div class="skeleton-header">
          <div class="skeleton skeleton-name"></div>
          <div class="skeleton skeleton-symbol"></div>
        </div>
        <div class="skeleton skeleton-price"></div>
        <div class="skeleton skeleton-change"></div>
      </div>
    <% end %>
  </div>
</div>

