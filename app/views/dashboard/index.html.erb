              $<%= number_with_delimiter(@market_data[:stocks][:sp500][:price].round(2), delimiter: ',') %>
            </div>
            <div class="market-change <%= @market_data[:stocks][:sp500][:change] >= 0 ? 'positive' : 'negative' %>">
              <%= @market_data[:stocks][:sp500][:change] >= 0 ? '▲' : '▼' %>
              <%= @market_data[:stocks][:sp500][:change].abs.round(2) %>%
            </div>
          <% else %>
            <div class="market-error">
              <span class="error-icon">⚠️</span>
              <span class="error-text">Temporarily unavailable</span>
            </div>
          <% end %>
        </div>

